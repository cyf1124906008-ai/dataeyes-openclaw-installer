{
  "models": {
    "mode": "replace",
    "providers": {
      "dataeyes": {
        "baseUrl": "https://cloud.dataeyes.ai/v1",
        "api": "openai-responses",
        "apiKey": "{{DATAEYES_API_KEY}}",
        "models": [
          {
            "id": "gpt-5.4",
            "name": "GPT-5.4",
            "input": ["text", "image"],
            "contextWindow": 256000,
            "maxTokens": 8192
          },
          {
            "id": "claude-opus-4-6",
            "name": "Claude Opus 4.6",
            "input": ["text", "image"],
            "contextWindow": 256000,
            "maxTokens": 8192
          },
          {
            "id": "gemini-3.1-pro-preview-customtools",
            "name": "Gemini 3.1 Pro",
            "input": ["text", "image"],
            "contextWindow": 256000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "dataeyes/gpt-5.4",
        "fallbacks": [
          "dataeyes/gemini-3.1-pro-preview-customtools",
          "dataeyes/claude-opus-4-6"
        ]
      }
    }
  }
}
